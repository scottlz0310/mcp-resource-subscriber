{
  "name": "mcp-resource-subscriber",
  "version": "0.1.3",
  "description": "CLI probe for MCP resource subscriptions — subscribe to MCP resources, receive live update notifications, and re-read updated content.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "resources-subscribe",
    "mcp-client",
    "cli",
    "probe",
    "notifications"
  ],
  "homepage": "https://github.com/scottlz0310/mcp-resource-subscriber",
  "type": "module",
  "packageManager": "pnpm@11.4.0",
  "license": "MIT",
  "bin": {
    "mcp-resource-subscriber": "dist/src/client/cli.js"
  },
  "files": [
    "dist/src/client/",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/scottlz0310/mcp-resource-subscriber.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/server/index.js",
    "dev": "tsx src/server/index.ts",
    "probe:subscribe": "tsx scripts/subscribe-client.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "check": "biome check .",
    "format": "biome format --write .",
    "prepare": "lefthook install || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/express": "^5.0.6",
    "express": "^5.2.1",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "lefthook": "^2.1.8",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=26.2.0"
  }
}
